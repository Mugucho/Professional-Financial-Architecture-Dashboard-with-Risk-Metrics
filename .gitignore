# --- SEGURIDAD (Crítico) ---
# Archivo de variables de entorno con tus API Keys de Alpaca
.env

# --- ENTORNOS VIRTUALES ---
# No subir las librerías instaladas localmente
venv/
env/
ENV/
bin/
lib/
include/

# --- CACHÉ DE PYTHON ---
# Archivos temporales de compilación
__pycache__/
*.pyc
*.pyo
*.pyd

# --- IDEs Y SISTEMA ---
# Configuraciones de VS Code y archivos de sistema
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- DATOS Y LOGS ---
# Evitar subir datos pesados o registros de errores
*.log
*.csv
*.json
*.db